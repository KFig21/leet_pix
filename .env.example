# ───────────────────────────────────────────────────────────
# Copy to .env and fill in. Never commit real values.
# ───────────────────────────────────────────────────────────

# --- Supabase (project settings → API) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret used to verify Supabase access tokens on the server
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Database (Supabase → project settings → database) ---
# Pooled connection for the app, direct connection for migrations
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@host:5432/postgres

# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# --- Client (Vite — must be prefixed with VITE_) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:4000
