{
  "name": "@leetpix/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "db:seed": "dotenv -e ../.env -- tsx prisma/seed.ts",
    "import:teams": "dotenv -e ../.env -- tsx scripts/importTeams.ts",
    "import:players": "dotenv -e ../.env -- tsx scripts/importPlayers.ts",
    "import:stats": "dotenv -e ../.env -- tsx scripts/importStats.ts",
    "import:mlbstats": "dotenv -e ../.env -- tsx scripts/importMlbStats.ts",
    "import:games": "dotenv -e ../.env -- tsx scripts/importGames.ts",
    "resolve:poll": "dotenv -e ../.env -- tsx scripts/resolvePoll.ts",
    "resolve:due": "dotenv -e ../.env -- tsx scripts/resolveDue.ts",
    "lock:due": "dotenv -e ../.env -- tsx scripts/lockDue.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@leetpix/shared": "*",
    "@prisma/client": "^6.1.0",
    "@supabase/supabase-js": "^2.47.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jose": "^5.9.6",
    "node-cron": "^4.6.0",
    "obscenity": "^0.4.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
