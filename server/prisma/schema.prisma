// LeetPix data model.
// Auth (auth.users) is owned by Supabase. `Profile.id` == Supabase auth user id.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Sport {
  FOOTBALL
  BASEBALL
}

// What a user is allowed to DO (permissions). Orthogonal to UserTier (billing).
// SUPERADMIN is the internal "god" role for you + employees: bypasses every
// entitlement limit and permission check. ADMIN/MODERATOR are delegable staff
// roles you may never assign until you hire.
enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPERADMIN
}

// What a user has PAID for. Drives entitlement limits (see @leetpix/shared
// TIER_LIMITS). Orthogonal to UserRole. Staff roles bypass tier limits.
enum UserTier {
  BASE
  PREMIUM
}

// Moderation report lifecycle (schema only for now — no UI/queue yet).
enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// What a report points at. IDs are the target row's uuid (polymorphic, no FK).
enum ReportTargetType {
  POLL
  COMMENT
  PROFILE
}

enum League {
  NFL
  MLB
}

enum PollStatus {
  OPEN
  LOCKED
  RESOLVED
}

enum PollLockType {
  FIXED_TIME
  GAME_START
}

enum PollQuestionType {
  START
  BENCH
  ADD
  DROP
  TRADE_FOR
  TRADE_AWAY
  BUY_LOW
  KEEP
}

// The time horizon / league context a poll is framed in. Orthogonal to the
// question: gates which question types the creator offers and shows as a badge.
//  DAILY   → one slate/game (DFS-style)
//  SEASON  → rest-of-season (redraft: lineup, waivers, trades)
//  DYNASTY → multi-year value (keepers, long-term trades) — opinion only
enum PollHorizon {
  DAILY
  SEASON
  DYNASTY
}

enum NotificationType {
  FOLLOW // actor started following recipient
  VOTE // actor voted on recipient's poll
  POLL_OUTCOME // recipient's poll resolved
}

// Game lifecycle. Drives poll locking (first kickoff) and resolution (a poll
// grades only once every game it depends on is FINAL).
enum GameStatus {
  SCHEDULED // not started
  IN_PROGRESS // underway
  FINAL // completed; stats are final
  POSTPONED // called off / rescheduled — holds dependent polls open
}

// ── Users / social graph ───────────────────────────────────

model Profile {
  id          String   @id @db.Uuid // mirrors auth.users.id
  username    String   @unique
  displayName String
  bio         String?
  // Generic avatar (icon + colors), stored as JSON. No uploads.
  avatar      Json

  // Permissions (what you can do) and billing tier (what you paid for) — two
  // independent axes. Entitlement = staff role bypasses, else TIER_LIMITS[tier].
  role UserRole @default(USER)
  tier UserTier @default(BASE)

  // Billing hooks — nullable now, wired if/when Stripe is added. Entitlements
  // should derive from subscriptionStatus + currentPeriodEnd, not a manual flag.
  stripeCustomerId   String?
  subscriptionStatus String? // e.g. active / past_due / canceled
  currentPeriodEnd   DateTime?

  // When the user finished (or dismissed) the first-run walkthrough. Null = not
  // yet onboarded, so the tutorial auto-opens once — persisted server-side so it
  // doesn't re-show on every new device/browser.
  onboardedAt DateTime?

  // Soft delete: keeps the row (and any authored content's records) around for
  // moderation/recovery instead of a hard cascade.
  deletedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  polls          Poll[]
  votes          Vote[]
  scoringFormats ScoringFormat[]
  leagues        FantasyLeague[]

  following Follow[] @relation("follower")
  followers Follow[] @relation("following")

  notifications      Notification[] @relation("recipient")
  notificationsActed Notification[] @relation("actor")

  // Social/moderation (schema future-proofing — no UI yet).
  likes     Like[]
  comments  Comment[]
  reports   Report[]  @relation("reporter")
  blocking  Block[]   @relation("blocker")
  blockedBy Block[]   @relation("blocked")

  @@index([username])
  @@map("profiles")
}

// Directed follow edge.
model Follow {
  followerId  String  @db.Uuid
  followingId String  @db.Uuid
  follower    Profile @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   Profile @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// ── Social / moderation (future-proofing) ──────────────────
// These tables exist so an acquirer can build likes/comments/moderation without
// a migration. Intentionally NOT wired to any UI yet.

// A user liking a poll (one row per user per poll).
model Like {
  userId    String   @db.Uuid
  pollId    String   @db.Uuid
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, pollId])
  @@index([pollId])
  @@map("likes")
}

// A threaded comment on a poll. Soft-delete (deletedAt) and moderation hide
// (hiddenAt) present from day one so they never need a retrofit.
model Comment {
  id       String  @id @default(uuid()) @db.Uuid
  pollId   String  @db.Uuid
  poll     Poll    @relation(fields: [pollId], references: [id], onDelete: Cascade)
  authorId String  @db.Uuid
  author   Profile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Self-relation for replies. Null = top-level comment.
  parentId String?   @db.Uuid
  parent   Comment?  @relation("thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("thread")

  body String

  deletedAt DateTime? // author removed
  hiddenAt  DateTime? // moderator hid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pollId, createdAt])
  @@index([parentId])
  @@map("comments")
}

// A user report against a poll/comment/profile. Polymorphic target (no FK).
model Report {
  id         String           @id @default(uuid()) @db.Uuid
  reporterId String           @db.Uuid
  reporter   Profile          @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType ReportTargetType
  targetId   String           @db.Uuid
  reason     String
  status     ReportStatus     @default(OPEN)
  createdAt  DateTime         @default(now())

  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

// A directed block edge (blocker hides/ignores blocked). Mirrors Follow.
model Block {
  blockerId String  @db.Uuid
  blockedId String  @db.Uuid
  blocker   Profile @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   Profile @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

// ── Polls / options / votes ────────────────────────────────

model Poll {
  id       String       @id @default(uuid()) @db.Uuid
  authorId String       @db.Uuid
  author   Profile      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sport        Sport
  questionType PollQuestionType
  // Framing/league context (default backfills existing rows as season-long).
  horizon      PollHorizon      @default(SEASON)
  status       PollStatus       @default(OPEN)
  lockType PollLockType
  lockAt   DateTime? // resolved lock time (set explicitly or derived from game start)

  // Number of weeks the outcome is tallied over (add/drop polls). Null = a
  // single game (start/bench) or not scored (opinion).
  evaluationWeeks Int?

  // Keeper polls only: number of teams in the league. Lets a per-option keeper
  // cost (round + pick) resolve to an overall pick number. Null otherwise.
  leagueSize Int?

  // Scoring: exactly one of preset/customFormat applies — unless a league is
  // attached, in which case scoring comes from the league and both stay null.
  scoringPreset   String?
  scoringFormatId String?        @db.Uuid
  scoringFormat   ScoringFormat? @relation(fields: [scoringFormatId], references: [id], onDelete: SetNull)

  // Frozen effective scoring rules captured at creation, so later edits to the
  // referenced league/format can't silently re-score this poll. Resolution and
  // projections prefer this snapshot when present.
  resolvedScoring Json?

  // Optional league context (teams + starting lineup + scoring). Informs voters
  // of positional value and supplies the keeper leagueSize.
  leagueId String?        @db.Uuid
  league   FantasyLeague? @relation(fields: [leagueId], references: [id], onDelete: SetNull)

  // The season/week the poll is graded against (add/drop spans week..week+N-1).
  season Int?
  week   Int?

  // Soft delete (author removal after it has votes) vs moderation hide. Kept so
  // voters' graded records survive a poll's removal. Hard delete only pre-votes.
  deletedAt DateTime?
  hiddenAt  DateTime?

  // Denormalized engagement counters for cheap feed rendering.
  likeCount    Int @default(0)
  commentCount Int @default(0)

  createdAt DateTime @default(now())
  resolvedAt DateTime?

  options       PollOption[]
  votes         Vote[]
  notifications Notification[]
  likes         Like[]
  comments      Comment[]
  // The specific games this poll depends on, captured at creation. The poll
  // locks at the earliest kickoff and grades once all of these are FINAL.
  games         PollGame[]

  @@index([authorId, createdAt])
  @@index([status, lockAt])
  @@map("polls")
}

// Join: which games gate a poll. Frozen at creation so trades don't drift the
// dependency set. Many-to-many because a poll's players can span several games.
model PollGame {
  pollId String @db.Uuid
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  gameId String @db.Uuid
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([pollId, gameId])
  @@index([gameId])
  @@map("poll_games")
}

model PollOption {
  id         String  @id @default(uuid()) @db.Uuid
  pollId     String  @db.Uuid
  poll       Poll    @relation(fields: [pollId], references: [id], onDelete: Cascade)
  playerId   String // id from the stats source
  playerName String
  // Keeper polls only: the draft round forfeited to keep this player (the cost
  // side of a keeper decision). Null for every other question type.
  keeperRound Int?
  // Optional pick within that round; with the poll's leagueSize this yields the
  // true overall pick number (e.g. 10-team R5 P7 → pick 47).
  keeperPick Int?
  // Projected fantasy points under the poll's scoring format (filled at lock).
  projectedPoints Float?
  // Set when the poll resolves: the actual scored points for this option.
  actualPoints    Float?
  isWinner        Boolean @default(false)

  votes Vote[]

  @@index([pollId])
  @@map("poll_options")
}

model Vote {
  id       String     @id @default(uuid()) @db.Uuid
  pollId   String     @db.Uuid
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId String     @db.Uuid
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voterId  String     @db.Uuid
  voter    Profile    @relation(fields: [voterId], references: [id], onDelete: Cascade)

  // Snapshot of this option's vote share at cast time (for risk weighting).
  consensusAtVote Float?

  createdAt DateTime @default(now())
  result    PollResult?

  // One vote per user per poll.
  @@unique([pollId, voterId])
  @@index([voterId, createdAt])
  @@map("votes")
}

// Graded outcome of a vote once its poll resolves. Drives all profile stats.
model PollResult {
  id      String  @id @default(uuid()) @db.Uuid
  voteId  String  @unique @db.Uuid
  vote    Vote    @relation(fields: [voteId], references: [id], onDelete: Cascade)
  correct Boolean
  // Risk-adjusted score: low consensus + correct => high; high consensus + correct => mild.
  score   Float
  resolvedAt DateTime @default(now())

  @@index([resolvedAt])
  @@map("poll_results")
}

// ── Notifications ──────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  recipientId String           @db.Uuid
  recipient   Profile          @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  // The user who triggered it (follower/voter). Null for system events.
  actorId     String?          @db.Uuid
  actor       Profile?         @relation("actor", fields: [actorId], references: [id], onDelete: Cascade)
  type        NotificationType
  // Related poll for VOTE / POLL_OUTCOME.
  pollId      String?          @db.Uuid
  poll        Poll?            @relation(fields: [pollId], references: [id], onDelete: Cascade)
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([recipientId, read])
  @@index([recipientId, createdAt])
  @@map("notifications")
}

// ── Teams ──────────────────────────────────────────────────
// Canonical team registry (seeded from packages/shared). Players and games
// reference a team by id; `abbreviation` stays denormalized on those rows as a
// display cache. See @leetpix/shared `TEAMS`.

model Team {
  id           String  @id @default(uuid()) @db.Uuid
  sport        Sport
  league       League
  abbreviation String // canonical (Sleeper for NFL, MLB Stats API for MLB)
  location     String
  name         String
  primaryColor String
  espnAbbr     String? // ESPN's abbreviation when it differs (schedule joins)

  players   Player[]
  homeGames Game[]   @relation("homeTeam")
  awayGames Game[]   @relation("awayTeam")

  @@unique([sport, abbreviation])
  @@map("teams")
}

// ── Players ────────────────────────────────────────────────
// Canonical player table. Poll options reference these by id (via a snapshot),
// and external source ids let us join projections/stats later.

model Player {
  id        String  @id @default(uuid()) @db.Uuid
  sport     Sport
  fullName  String
  firstName String?
  lastName  String?
  // Denormalized team abbreviation cache; teamId is the canonical reference.
  team      String?
  teamId    String? @db.Uuid
  teamRef   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  position  String?
  active    Boolean @default(true)
  // Latest injury designation from the source (Questionable/Out/IR/…). Null = healthy.
  injuryStatus String?

  // External source ids (for future projections / live stats).
  sleeperId String? @unique
  espnId    String?
  yahooId   String?
  mlbamId   String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stats PlayerStat[]

  @@index([sport, active, fullName])
  @@index([fullName])
  @@index([teamId])
  @@map("players")
}

enum PlayerStatKind {
  ACTUAL
  PROJECTION
}

// A player's stat line for one period (NFL: season+week), normalized to our
// canonical stat keys. `ACTUAL` grades polls; `PROJECTION` powers projected pts.
model PlayerStat {
  id       String         @id @default(uuid()) @db.Uuid
  playerId String         @db.Uuid
  player   Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season   Int
  week     Int
  kind     PlayerStatKind
  stats    Json // canonical stat line, e.g. { passingYards: 305, passingTd: 2 }
  source   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, season, week, kind])
  @@index([season, week, kind])
  @@map("player_stats")
}

// ── Schedule ───────────────────────────────────────────────
// Upcoming/played games, used to (a) derive real GAME_START lock times and
// (b) show players' opponent + kickoff on polls. Imported from ESPN (NFL) and
// the MLB Stats API. Teams are stored as the same abbreviations as Player.team.

model Game {
  id       String @id @default(uuid()) @db.Uuid
  sport    Sport
  season   Int
  // NFL game week. Null for sports without a weekly structure (MLB).
  week     Int?
  // Denormalized team abbreviation caches; the *Id fields are canonical refs.
  homeTeam String
  awayTeam String
  homeTeamId String? @db.Uuid
  awayTeamId String? @db.Uuid
  homeTeamRef Team?  @relation("homeTeam", fields: [homeTeamId], references: [id])
  awayTeamRef Team?  @relation("awayTeam", fields: [awayTeamId], references: [id])
  kickoff  DateTime
  // Normalized lifecycle status (from the source's status).
  status   GameStatus @default(SCHEDULED)
  // Set once this game's box scores have been imported. Lets the status sync
  // import a period's stats exactly once per FINAL game (and retry on failure).
  statsImportedAt DateTime?
  source   String // "espn" | "mlb"
  sourceId String // stable id within a source (ESPN event id / MLB gamePk)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  polls PollGame[]

  @@unique([source, sourceId])
  @@index([sport, season, week])
  @@index([sport, kickoff])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("games")
}

// ── Custom scoring formats ─────────────────────────────────

model ScoringFormat {
  id       String  @id @default(uuid()) @db.Uuid
  ownerId  String  @db.Uuid
  owner    Profile @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name     String
  sport    Sport
  // statKey -> points per unit
  rules    Json
  createdAt DateTime @default(now())

  polls   Poll[]
  leagues FantasyLeague[]

  @@unique([ownerId, name])
  @@map("scoring_formats")
}

// ── Leagues ────────────────────────────────────────────────
// A reusable league profile (owned by a user): team count + starting lineup +
// scoring. Attaching one to a poll tells voters how valuable a position is
// (positional scarcity) and supplies the keeper leagueSize.

model FantasyLeague {
  id       String  @id @default(uuid()) @db.Uuid
  ownerId  String  @db.Uuid
  owner    Profile @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name     String
  sport    Sport
  numTeams Int
  // Starting-lineup slot counts + bench, keyed by slot
  // (QB/RB/WR/TE/FLEX/SUPERFLEX/K/DST/BENCH). See @leetpix/shared LineupSlots.
  lineup   Json
  // The league's scoring (exactly one), mirroring Poll.
  scoringPreset   String?
  scoringFormatId String?        @db.Uuid
  scoringFormat   ScoringFormat? @relation(fields: [scoringFormatId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  polls Poll[]

  @@unique([ownerId, name])
  @@map("leagues")
}

// ── Scheduler coordination ─────────────────────────────────

// A short-lived lease per scheduled job so that, if multiple server instances
// run, only one executes a given job at a time. Pool-safe (unlike session
// advisory locks) and self-healing (a crashed holder's lease simply expires).
model JobLock {
  name        String   @id
  lockedUntil DateTime
  instanceId  String
  updatedAt   DateTime @updatedAt

  @@map("job_locks")
}
